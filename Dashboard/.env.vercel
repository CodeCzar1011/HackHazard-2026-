# Vercel Environment Variables
# Add these to your Vercel project dashboard

# Backend API configuration
VITE_API_BASE_URL=https://hackhazard-backend.onrender.com
VITE_WS_URL=wss://hackhazard-backend.onrender.com/api/v1/ws/alerts

# Public API URLs (Next.js style)
NEXT_PUBLIC_API_BASE_URL=https://hackhazard-backend.onrender.com
NEXT_PUBLIC_WS_URL=wss://hackhazard-backend.onrender.com/api/v1/ws/alerts

# Analytics (optional)
# VITE_ANALYTICS_ID=

# Feature flags (optional)
# VITE_ENABLE_DARK_MODE=true
