# GuardAIian Backend - Render.com Production Configuration
# Copy these to your Render environment variables dashboard

# Core Application
APP_ENV=prod
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true
APP_NAME=GuardAIian

# API Security
BACKEND_CORS_ORIGINS=["https://alitatech.xyz"]
MAX_REQUEST_BODY_BYTES=1000000

# Database - SQLite for simplicity (can upgrade to PostgreSQL)
# For Render, use SQLite with persistent volumes
DATABASE_URL=sqlite+aiosqlite:///./guardaiian.db
AUTO_CREATE_TABLES=true
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis - Optional, but recommended for production rate limiting
# Render can add Redis addon, or leave empty to disable
REDIS_URL=
RATE_LIMIT_REQUESTS_PER_MINUTE=600
RATE_LIMIT_FAIL_CLOSED=true

# Vector Storage (Chroma)
CHROMA_PERSIST_DIR=./chroma_data
ALLOW_IN_MEMORY_VECTOR_FALLBACK=true
SEED_VECTORSTORE_ON_STARTUP=true

# Embeddings
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
LOAD_EMBEDDING_MODEL_ON_STARTUP=false
USE_HASH_EMBEDDINGS_FALLBACK=true
HASH_EMBEDDING_DIMENSIONS=384

# Security - CHANGE THESE TO RANDOM VALUES!
REQUIRE_API_KEY=false
DASHBOARD_API_KEY=GENERATE_A_RANDOM_SECRET_HERE
API_KEY_HEADER_NAME=x-guardaiian-api-key
JWT_SECRET_KEY=GENERATE_A_LONG_RANDOM_SECRET_HERE_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
DASHBOARD_ADMIN_EMAIL=admin@guardaiian.prod
DASHBOARD_ADMIN_PASSWORD=GENERATE_A_STRONG_PASSWORD_HERE
DASHBOARD_ADMIN_NAME=GuardAIian Admin

# LLM Routing - Choose your provider
DEFAULT_LLM_PROVIDER=local
LOCAL_LLM_ENDPOINT=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_RETRY_ATTEMPTS=2

# Request Validation
REQUEST_SIZE_LIMIT_MB=10
